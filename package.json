{
  "name": "streamdrop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Generate listening-friendly HTML queues from Raindrop articles.",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "start": "tsx scripts/dev.ts",
    "backfill:elevenreader-html": "tsx scripts/backfill-elevenreader-html.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "drizzle-orm": "^0.45.2",
    "jsdom": "^26.1.0",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.7.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
