DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# Runtime queue generation still reads the Raindrop/config values below from env vars.
# When the user tables are empty, APP_USERNAME/APP_PASSWORD bootstrap the first owner
# and seed that owner's initial user_settings record from these values.
RAINDROP_TOKEN=your_token_here
RAINDROP_PROCESSED_COLLECTION_ID=
# Bootstrap owner credentials for database-backed auth.
# Also used by the legacy no-database auth fallback.
APP_USERNAME=streamdrop
APP_PASSWORD=[REDACTED:password]
# Used by the legacy signed-cookie auth fallback and as a fallback HTML link secret.
SESSION_SECRET=[REDACTED:secret-value]
HTML_LINK_SIGNING_SECRET=[REDACTED:secret-value]
HTML_LINK_TTL_SECONDS=2592000
RAINDROP_COLLECTION_ID=0
RAINDROP_SEARCH=
MAX_MINUTES=45
WORDS_PER_MINUTE=180
MAX_ARTICLES=20
EXTRACTION_CONCURRENCY=4
FETCH_TIMEOUT_MS=12000
MAX_HTML_BYTES=750000
